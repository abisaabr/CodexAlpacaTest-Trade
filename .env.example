# Paper-only repo lock: do not commit real values, do not set LIVE_TRADING=true,
# and do not point APCA_API_BASE_URL at any live or custom trading endpoint.
# Fill only one credential family. Do not commit your real values.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=

ALPACA_PAPER_TRADE=true
# Optional, but if set it must remain the Alpaca paper endpoint.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

ALPACA_DATA_FEED=iex
DEFAULT_UNDERLYINGS=SPY,QQQ
DATA_ROOT=data
REPORTS_ROOT=reports
LOG_LEVEL=INFO
LIVE_TRADING=false
MAX_NOTIONAL_PER_TRADE=1000
MAX_OPEN_POSITIONS=3
MAX_ORDERS_PER_RUN=3
DRY_RUN=true
REQUEST_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3
